{
  "name": "fhir-persistence",
  "version": "0.0.1",
  "description": "",
  "homepage": "https://github.com/medxaidev/fhir-persistence#readme",
  "license": "MIT",
  "author": "Fangjun <fangjun20208@gmail.com>",
  "keywords": [
    "fhir",
    "fhir-r4",
    "fhir-server",
    "fhir-runtime",
    "fhirpath",
    "healthcare",
    "hl7",
    "medical",
    "interoperability",
    "validator",
    "validation",
    "parser",
    "snapshot",
    "profile",
    "structuredefinition",
